# Copy this file to .env.local and fill in your own key.
# Get a Gemini API key at https://aistudio.google.com/apikey
#
# The app runs fully without this key: every AI-backed endpoint falls back to a
# deterministic, rule-based response so the demo, tests, and CI never require a
# real credential. Set this only to see live Gemini-generated recommendations.
GEMINI_API_KEY=
